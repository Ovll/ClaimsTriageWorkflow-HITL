# Provider switch
LLM_PROVIDER=azure          # azure | openai | ollama

# Azure OpenAI (used when LLM_PROVIDER=azure)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o

# Direct OpenAI (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o

# Local Ollama (used when LLM_PROVIDER=ollama)
# dotnet run:           http://localhost:11434/v1
# docker compose run:   http://host.docker.internal:11434/v1
OLLAMA_ENDPOINT=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:7b

# Domain config
AMOUNT_THRESHOLD=10000
CONFIDENCE_THRESHOLD=0.65

# Audit log (JSONL, one record per claim; default: audit.log in working directory)
# AUDIT_LOG_PATH=audit.log
